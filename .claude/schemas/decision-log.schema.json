{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claudekit.cc/schemas/decision-log.schema.json",
  "title": "Plan Decision Log Entry",
  "description": "One line of decisions.log.jsonl — the append-only single source of truth for a plan. plan.md and phase-XX-*.md are generated from these entries by plan-derive.cjs. Entries are never edited or removed; supersede a decision by appending a new one with `supersedes`.",
  "type": "object",
  "required": ["kind"],
  "properties": {
    "id": { "type": "string", "description": "Stable id (D{n}) assigned at append time. Never reused." },
    "ad": { "type": "string", "description": "Decision id (AD-{m}), assigned at append time for kind=decision." },
    "kind": { "type": "string", "enum": ["meta", "phase", "decision", "task"] }
  },
  "oneOf": [
    {
      "title": "meta",
      "properties": {
        "kind": { "const": "meta" },
        "title": { "type": "string" },
        "strategy": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["kind", "title"]
    },
    {
      "title": "phase",
      "properties": {
        "kind": { "const": "phase" },
        "phase": { "type": "integer", "minimum": 1 },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "priority": { "type": "string", "enum": ["P1", "P2", "P3"] },
        "effort": { "type": "string" },
        "tranche": { "type": "string" },
        "deps": { "type": "array", "items": { "type": "integer" } },
        "overview": { "type": "string" }
      },
      "required": ["kind", "phase", "title"]
    },
    {
      "title": "decision",
      "properties": {
        "kind": { "const": "decision" },
        "phase": { "type": ["integer", "null"], "description": "Phase this decision belongs to, or null for plan-level." },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "supersedes": { "type": ["string", "null"], "description": "AD id of a prior decision this one replaces; the superseded decision is dropped from derived output." }
      },
      "required": ["kind", "title"]
    },
    {
      "title": "task",
      "properties": {
        "kind": { "const": "task" },
        "phase": { "type": "integer", "minimum": 1 },
        "text": { "type": "string" }
      },
      "required": ["kind", "phase", "text"]
    }
  ]
}
